# =====================================================
# Señas Co — .gitignore
# =====================================================

# ---------- Entornos virtuales ----------
venv/
env/
.venv/
ENV/

# ---------- Variables de entorno / secretos ----------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# ---------- Testing / Cobertura ----------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# ---------- IDEs / editores ----------
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
.claude/

# ---------- Sistema operativo ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------- Logs ----------
*.log
logs/

# ---------- Recursos generados / locales ----------
instance/
*.db
*.sqlite
*.sqlite3

# ---------- Modelos LLM descargados (gpt4all) ----------
*.gguf
*.bin

# ---------- Archivos temporales ----------
*.tmp
*.bak
*.orig
