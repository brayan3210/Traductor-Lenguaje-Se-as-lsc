# ============================================================
# Señas Co — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# --- Flask ---
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=cambia-esta-clave-en-produccion

# --- MySQL (XAMPP por defecto) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=traductor_lsc

# --- NLP ---
SPACY_MODEL=es_core_news_md
MAX_TOKENS=80

# --- Servidor ---
HOST=0.0.0.0
PORT=5000

# --- SMTP / Email (Gmail App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_FROM_NAME=Señas Co
APP_BASE_URL=http://127.0.0.1:5000

# --- 2FA ---
TOTP_ISSUER=Señas Co

# --- Google OAuth (consola: https://console.cloud.google.com) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/api/auth/google/callback
